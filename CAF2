local isCurrentlyBlocking = false
local lastParryTime = 0
local punchToggleState = false

-- Helper functions
local function guard() Combat:FireServer("guarding") end

local function ensureGuard()
    local myC = lp.Character
    if myC and not myC:HasTag("guarding") then
        Combat:FireServer("guarding")
    end
end

local function block()
    ensureGuard()
    if not isCurrentlyBlocking then
        isCurrentlyBlocking = true
        Combat:FireServer("block")
    end
end

local function unblock()
    if isCurrentlyBlocking then
        isCurrentlyBlocking = false
        Combat:FireServer("unblock")
    end
end

local function forceParry()
    Combat:FireServer("unblock")
    task.wait(0.01)
    Combat:FireServer("block")
    isCurrentlyBlocking = true
    lastParryTime = tick()
end

local function validEnemy(p, char)
    if p == lp or not char then return false end
    if lp:FindFirstChild("Party") and p:FindFirstChild("Party")
        and lp.Party.Value == p.Party.Value then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hrp ~= nil and hum ~= nil and hum.Health > 0
end

local function nearest(range)
    local myC = lp.Character
    if not myC then return nil end
    local myHRP = myC:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end
    local best, bestD = nil, range or math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        local c = p.Character
        if validEnemy(p, c) then
            local d = (myHRP.Position - c.HumanoidRootPart.Position).Magnitude
            if d < bestD then best, bestD = c, d end
        end
    end
    return best
end

-- ScreenGui for parenting ESP Highlights to avoid recreation bugs
