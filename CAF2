-- Outline ESP (Direct parenting to ScreenGui with Adornee matching)
local function espApply(p)
    if p == lp then return end
    local char = p.Character
    if not char then return end

    local d = espData[p]
    if d and d.hl and d.hl.Parent == sg and d.hl.Adornee == char then
        return
    end

    if d then
        pcall(function() if d.hl then d.hl:Destroy() end end)
        espData[p] = nil
    end

    local hl = Instance.new("Highlight")
    hl.Name = "ESPHighlight_" .. p.Name
    hl.FillColor           = Color3.fromRGB(239, 68, 68)
    hl.OutlineColor        = Color3.fromRGB(239, 68, 68)
    hl.FillTransparency    = 1
    hl.OutlineTransparency = 0
    hl.Adornee = char
    hl.Parent  = sg

    espData[p] = { hl=hl }
end

local function espClear(p)
    local d = espData[p]
    if not d then return end
    pcall(function() if d.hl then d.hl:Destroy() end end)
    espData[p] = nil
end

-- Keep ESP updated via efficient thread loop
task.spawn(function()
    while task.wait(0.2) do
        if flags.esp then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= lp and p.Character then
                    espApply(p)
                end
            end
        else
            for p in pairs(espData) do
                espClear(p)
            end
        end
    end
end)

-- Safe Mode Punch Animation
local function playPunchAnim()
    local char = lp.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local animator = hum and hum:FindFirstChildOfClass("Animator")
    if animator then
        local animsFolder = ReplicatedStorage:FindFirstChild("Animations")
        local combatFolder = animsFolder and animsFolder:FindFirstChild("Combat")
        local defaultFolder = combatFolder and combatFolder:FindFirstChild("Default")
        if defaultFolder then
            punchToggleState = not punchToggleState
            local anim = punchToggleState and defaultFolder:FindFirstChild("L") or defaultFolder:FindFirstChild("R")
            if anim then
                local track = animator:LoadAnimation(anim)
                track:Play()
            end
        end
    end
end

-- Character spawn management
local function onSpawn(char)
    task.spawn(function()
        task.wait(1.5)
        guard()
        if flags.walkSpeed then
            local h = char:FindFirstChildOfClass("Humanoid")
            if h then h.WalkSpeed = flags.wsValue end
        end
    end)
end
if lp.Character then onSpawn(lp.Character) end
lp.CharacterAdded:Connect(onSpawn)

-- Hook animations for Auto Parry
local attackAnimationNames = {
    ["l"] = true,
    ["r"] = true,
    ["kick"] = true,
    ["roundkick"] = true,
    ["head"] = true,
    ["grab"] = true,
    ["leftgroundpunch"] = true,
    ["rightgroundpunch"] = true,
    ["slam"] = true
}

local function isAttacking(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    local animator = hum and hum:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            local anim = track.Animation
            local name = anim and anim.Name
            if name then
                local lname = string.lower(name)
                if attackAnimationNames[lname] or string.find(lname, "punch") or string.find(lname, "kick") or string.find(lname, "slam") then
                    if track.IsPlaying and track.TimePosition < 0.4 then
                        return true
                    end
                end
            end
        end
    end
    return false
end

local function checkIncomingAttacks()
    local myC = lp.Character
    if not myC then return false end
    local myHRP = myC:FindFirstChild("HumanoidRootPart")
    if not myHRP then return false end
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp then
            local c = p.Character
            if validEnemy(p, c) then
                local hrp = c:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (myHRP.Position - hrp.Position).Magnitude
                    if dist <= flags.parryRange then
                        if isAttacking(c) then
                            return true
                        end
                    end
                end
            end
        end
    end
    return false
end

local function monitorAnimations()
    local function hookPlayer(p)
        if p == lp then return end
        local function hookChar(char)
            local hum = char:WaitForChild("Humanoid", 10)
            local animator = hum and hum:WaitForChild("Animator", 10)
            if animator then
                animator.AnimationPlayed:Connect(function(track)
                    if not flags.autoParry then return end
                    local anim = track.Animation
                    local name = anim and anim.Name
                    if name then
                        local lname = string.lower(name)
                        if attackAnimationNames[lname] or string.find(lname, "punch") or string.find(lname, "kick") or string.find(lname, "slam") then
                            local myC = lp.Character
                            local myHRP = myC and myC:FindFirstChild("HumanoidRootPart")
                            local hrp = char:FindFirstChild("HumanoidRootPart")
                            if myHRP and hrp then
                                local dist = (myHRP.Position - hrp.Position).Magnitude
                                if dist <= flags.parryRange then
                                    forceParry()
                                end
                            end
                        end
                    end
                end)
            end
        end
        if p.Character then task.spawn(hookChar, p.Character) end
        p.CharacterAdded:Connect(hookChar)
    end
    
    for _, p in ipairs(Players:GetPlayers()) do
        hookPlayer(p)
    end
    Players.PlayerAdded:Connect(hookPlayer)
end

-- Main update loop
RunService.Heartbeat:Connect(function()
    local now = tick()
    local myC = lp.Character
    if not myC then return end
    local myHRP = myC:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    local myHum = myC:FindFirstChildOfClass("Humanoid")

    -- Inf Stamina
    if (flags.infStamina or flags.autoSlam) and now - lastGuard > GUARD_INTERVAL then
        lastGuard = now
        guard()
    end

    -- WalkSpeed Bypass
    if flags.walkSpeed and myHum and myHum.WalkSpeed ~= flags.wsValue then
        myHum.WalkSpeed = flags.wsValue
    end

    -- Auto Slam
    if flags.autoSlam and now - lastSlam >= SLAM_CD then
        if not myC:HasTag("slamming") and not myC:HasTag("slammed") then
            local t = nearest(flags.slamRange)
            if t and not t:HasTag("slammed") then
                lastSlam = now
                Combat:FireServer("slam", t)
            end
        end
    end

    -- Kill Aura (Unblocks automatically to bypass server-side block check, then re-blocks)
    if flags.killAura and now - lastKill >= flags.killAuraCD then
        local t = nearest(flags.killRange)
        if t then
            lastKill = now
            task.spawn(function()
                local wasBlocking = isCurrentlyBlocking
                if wasBlocking then
                    Combat:FireServer("unblock")
                    task.wait(0.015)
                end

                Combat:FireServer("fist")
                Combat:FireServer("body", t, false)

                if flags.killAuraSafe then
                    playPunchAnim()
                end

                if wasBlocking then
                    task.wait(0.015)
                    Combat:FireServer("block")
                end
            end)
        end
    end

    -- Auto Parry execution
    if flags.autoParry then
        if checkIncomingAttacks() then
            if now - lastParryTime > 0.4 then
                forceParry()
            end
        end
    end

    -- Auto Block execution
    if flags.autoBlock then
        local enemy = nearest(flags.blockRange)
        if enemy then
            block()
        else
            if not flags.autoParry or (now - lastParryTime > 0.4) then
                unblock()
            end
        end
    else
        if not flags.autoParry or (now - lastParryTime > 0.4) then
            unblock()
        end
    end
end)

Players.PlayerRemoving:Connect(espClear)
monitorAnimations()

