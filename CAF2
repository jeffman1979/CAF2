-- Robust Cleanup of all previous UI instances across PlayerGui and gethui
local function cleanup()
    local names = { "CAF2HubPremium", "CAF2Hub" }
    pcall(function()
        local h = type(gethui) == "function" and gethui()
        if h then
            for _, c in ipairs(h:GetChildren()) do
                for _, name in ipairs(names) do
                    if c.Name == name then c:Destroy() end
                end
            end
        end
    end)
    pcall(function()
        for _, c in ipairs(pg:GetChildren()) do
            for _, name in ipairs(names) do
                if c.Name == name then c:Destroy() end
            end
        end
    end)
end
